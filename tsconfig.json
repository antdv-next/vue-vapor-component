{
  "compilerOptions": {
    // "baseUrl": ".",
    "composite": true,
    /* Linting */
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noUncheckedSideEffectImports": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext"
  },

  "paths": {
    "@/*": ["./packages/*/src/*"]
  }
}
