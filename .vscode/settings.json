{
  "cSpell.ignoreWords": [
    // 忽略的单词
    "vitejs",
    "selicens",
    "vite",
    "qrcode",
    "tsdown",
    "unplugin-vue",
    "oxlint",
    "oxfmt"
  ],
  "oxc.fmt.configPath": "./vite.config.ts",
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  }
}
